<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_blue"
    tools:context=".View.Pomodoro.PomodoroActivity"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- BOTÓN SALIR -->
    <ImageButton
        android:id="@+id/btnStop"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/ic_arrow_back"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Salir"
        android:scaleType="fitCenter"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- TIMER GRANDE -->
    <TextView
        android:id="@+id/tvTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="14:08"
        android:textColor="@color/dark_blue"
        android:textSize="100sp"
        android:textStyle="bold"
        android:fontFamily="@font/chocolate_and_vanilla"
        android:letterSpacing="0.05"
        android:layout_marginTop="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="25:00" />

    <!-- CÍRCULO CON LA MASCOTA -->
    <FrameLayout
        android:id="@+id/layoutMascotContainer"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvTimer"
        app:layout_constraintBottom_toTopOf="@id/btnPlayPause"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Fondo verde -->
        <View
            android:id="@+id/viewCircleBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:background="@drawable/bg_circle_light_green" />

        <!-- Mascota -->
        <ImageView
            android:id="@+id/ivMascot"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_gravity="center"
            android:src="@drawable/anim_baby_reading"
            android:contentDescription="Mascota estudiando"
            android:scaleType="centerInside" />

        <!-- Arco exterior — más grande que el FrameLayout -->
        <com.example.blobbugotchi.View.Pomodoro.CircularTimerView
            android:id="@+id/circularTimer"
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_gravity="center" />

    </FrameLayout>

    <!-- BOTÓN PLAY/PAUSA — centrado abajo -->
    <ImageButton
        android:id="@+id/btnPlayPause"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:src="@drawable/ic_play"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Iniciar o pausar"
        android:scaleType="fitCenter"
        android:layout_marginBottom="56dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>