<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/menu_minigame_bg">

    <!-- Bloque de botones anclado a la parte inferior-central -->
    <LinearLayout
        android:id="@+id/layoutButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="64dp"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="48dp">

        <!-- Record con fondo semitransparente tipo chip -->
        <TextView
            android:id="@+id/tvHighScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏆 Sin récord aún"
            android:textSize="14sp"
            android:textColor="#FFD700"
            android:textStyle="bold"
            android:background="@drawable/chip_dark_bg"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:layout_marginBottom="28dp" />

        <!-- Botón JUGAR (más grande, más prominente) -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnStart"
            android:layout_width="240dp"
            android:layout_height="56dp"
            android:text="JUGAR"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:letterSpacing="0.15"
            android:background="@drawable/btn_minigame"
            android:elevation="8dp"
            android:stateListAnimator="@null" />

        <!-- Separador visual -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="10dp" />

        <!-- Botón AJUSTES -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSettings"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:text="AJUSTES"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:letterSpacing="0.1"
            android:background="@drawable/btn_minigame"
            android:elevation="4dp"
            android:stateListAnimator="@null" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="8dp" />

        <!-- Botón SALIR -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnExit"
            android:layout_width="160dp"
            android:layout_height="44dp"
            android:text="SALIR"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/btn_minigame"
            android:elevation="2dp"
            android:stateListAnimator="@null" />

    </LinearLayout>

</RelativeLayout>