<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_gallery_cell"
    android:padding="24dp"
    android:gravity="center">

    <!-- TÍTULO -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sesión de estudio"
        android:fontFamily="@font/arista_pro_alternate_bold"
        android:textStyle="bold"
        android:textSize="25sp"
        android:textColor="@color/black"/>

    <!-- SUBTÍTULO -->
    <TextView
        android:id="@+id/tv_result_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tiempo pasado con tu Blobbu"
        android:fontFamily="@font/arista_pro_alternate_bold"
        android:textSize="15sp"
        android:textColor="@color/dark_blue"
        android:gravity="center"
        android:layout_marginTop="4dp"/>

    <!-- TIEMPO -->
    <TextView
        android:id="@+id/tv_result_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00 min 00 s"
        android:fontFamily="sans-serif"
        android:textStyle="bold"
        android:textSize="40sp"
        android:textColor="@color/dark_blue"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"/>

    <!-- MENSAJE -->
    <TextView
        android:id="@+id/tv_result_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:fontFamily="@font/arista_pro_alternate_bold"
        android:textSize="13sp"
        android:textColor="@color/black"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="24dp"/>

    <!-- BOTONES -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btn_exit_pomodoro"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="SALIR"
            android:fontFamily="@font/arista_pro_alternate_bold"
            android:backgroundTint="@color/light_blue"
            android:textColor="@color/black"/>

        <Button
            android:id="@+id/btn_repeat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="OTRO POMODORO"
            android:fontFamily="@font/arista_pro_alternate_bold"
            android:backgroundTint="@color/dark_blue"
            android:textColor="@color/white"/>

    </LinearLayout>

</LinearLayout>