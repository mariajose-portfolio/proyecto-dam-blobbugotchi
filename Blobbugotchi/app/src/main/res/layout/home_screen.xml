<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_blue"
    android:layout_gravity="center"
    android:gravity="center">

    <!--  BARRAS DE ESTADO -->
    <LinearLayout
        android:id="@+id/statsBars"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <!-- Felicidad LVL -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HAPPY"
                android:fontFamily="@font/arista_pro_alternate_bold"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="60px"
                android:layout_marginEnd="8dp"/>

            <com.tamagotchi.Model.Stats.HappyProgressBar
                android:id="@+id/happyBar"
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1" />
        </LinearLayout>

        <!-- Hambre LVL -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HUNGER"
                android:fontFamily="@font/arista_pro_alternate_bold"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="60px"
                android:layout_marginEnd="8dp"/>

            <com.tamagotchi.Model.Stats.HungerIconsView
                android:id="@+id/hungerBar"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1" />
        </LinearLayout>

        <!-- Sueño LVL -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SLEEP"
                android:fontFamily="@font/arista_pro_alternate_bold"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="60px"
                android:layout_marginEnd="8dp"/>

            <com.tamagotchi.Model.Stats.SleepIconsView
                android:id="@+id/sleepBar"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1" />
        </LinearLayout>

    </LinearLayout>

    <!-- CARCASA TAMAGOTCHI  -->
    <FrameLayout
        android:id="@+id/deviceContainer"
        android:layout_width="380dp"
        android:layout_height="450dp"
        android:layout_centerHorizontal="true"
        android:layout_below="@id/statsBars"
        android:layout_marginTop="24dp">

        <!-- Fondo -->
        <ImageView
            android:id="@+id/screenImage"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center"
            android:translationY="15dp"
            android:scaleType="centerCrop"
            android:src="@drawable/screen_background" />

        <!-- Contenedor del blobbu -->
        <FrameLayout
            android:id="@+id/gameFragmentContainer"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center"
            android:translationY="15dp" />

        <!-- Carcasa -->
        <ImageView
            android:id="@+id/shellImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/tamagotchi_shell"
            android:scaleType="fitXY"
            android:clickable="false" />

        <!-- Botones carcasa -->
        <LinearLayout
            android:id="@+id/bottomButtons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_gravity="bottom|center_horizontal"
            android:paddingBottom="45dp">

            <ImageButton
                android:id="@+id/btn_menu"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_margin="12dp"
                android:background="@drawable/btn_small" />

            <ImageButton
                android:id="@+id/btn_accept"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_margin="12dp"
                android:background="@drawable/btn_small" />

            <ImageButton
                android:id="@+id/btn_cancel"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_margin="12dp"
                android:background="@drawable/btn_small" />
        </LinearLayout>
    </FrameLayout>

    <!-- BOTONES DE MENÚ -->
    <LinearLayout
        android:id="@+id/menuButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/deviceContainer"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="16dp"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/btn_pomodoro"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_margin="8dp"
            android:background="@drawable/btn_time" />

        <ImageButton
            android:id="@+id/btn_config"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/btn_config" />
    </LinearLayout>

</RelativeLayout>