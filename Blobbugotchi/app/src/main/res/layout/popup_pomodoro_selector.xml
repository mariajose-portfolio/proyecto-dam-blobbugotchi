<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_gallery_cell"
    android:padding="24dp"
    android:gravity="center">

    <!-- TÍTULO -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ELEGIR DURACIÓN"
        android:fontFamily="@font/arista_pro_alternate_bold"
        android:textStyle="bold"
        android:textSize="20sp"
        android:textColor="@color/black"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¿Cuánto tiempo quieres concentrarte?"
        android:fontFamily="@font/arista_pro_alternate_bold"
        android:textSize="13sp"
        android:textColor="@color/dark_blue"
        android:gravity="center"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="24dp"/>

    <!-- OPCIONES DE TIEMPO -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="4dp">

            <TextView android:id="@+id/opt_5"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="5"
                android:gravity="center"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_time_option_normal"
                android:layout_margin="4dp"/>

            <TextView android:id="@+id/opt_10"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="10"
                android:gravity="center"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_time_option_normal"
                android:layout_margin="4dp"/>

            <TextView android:id="@+id/opt_15"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="15"
                android:gravity="center"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/dark_blue"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_time_option_selected"
                android:layout_margin="4dp"/>

            <TextView android:id="@+id/opt_20"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="20"
                android:gravity="center"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_time_option_normal"
                android:layout_margin="4dp"/>

            <TextView android:id="@+id/opt_25"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="25"
                android:gravity="center"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_time_option_normal"
                android:layout_margin="4dp"/>

            <TextView android:id="@+id/opt_30"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="30"
                android:gravity="center"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_time_option_normal"
                android:layout_margin="4dp"/>

        </LinearLayout>

    </HorizontalScrollView>

    <!-- BOTONES -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btn_cancel_pomodoro"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="CANCELAR"
            android:fontFamily="@font/arista_pro_alternate_bold"
            android:backgroundTint="@color/light_blue"
            android:textColor="@color/black"/>

        <Button
            android:id="@+id/btn_confirm_pomodoro"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="INICIAR"
            android:fontFamily="@font/arista_pro_alternate_bold"
            android:backgroundTint="@color/dark_blue"
            android:textColor="@color/white"/>

    </LinearLayout>

</LinearLayout>